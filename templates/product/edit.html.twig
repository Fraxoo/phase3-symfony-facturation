{% extends 'base.html.twig' %}

{% block title %}Edit Product{% endblock %}

{% block body %}

<div class="flex justify-center items-center h-screen">
    <div class="auth-form w-1/3">
        <div class="flex justify-between">
            <div class="flex flex-col">
                <h3 class="font-bold text-[20px]">Produit - {{ product.name }}</h3>
                <p class="font-bold text-(--gray)">Modifier un produit</p>
            </div>
            <a href="{{ path('app_product_index')}}"><i class="fa-solid fa-xmark"></i></a>
        </div>
        {{ include('product/_form.html.twig', {'button_label': 'Update'}) }}
    </div>

</div>


{% endblock %}