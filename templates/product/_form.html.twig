{{ form_start(form , {
'attr' : { 'class' : "auth-form w-1/3 " }
}) }}

<div class="flex justify-between">
    <h3 class="font-bold text-[20px]">Nouveau Produit</h3>
    <a href="{{ path('app_product_index')}}"><i class="fa-solid fa-xmark"></i></a>
</div>
<div class="auth-input-div">
    <p class="text-(--gray)">Nom du produit</p>
    {{ form_widget(form.name , {
    'attr' : { 'class' : "auth-input" }
    }) }}
    <div class="alert">
        {{ form_errors(form.name) }}
    </div>
</div>
<div class="auth-input-div">
    <p class="text-(--gray)">Description</p>
    {{ form_widget(form.description , {
    'attr' : { 'class' : "auth-input" }
    }) }}
    <div class="alert">
        {{ form_errors(form.description) }}
    </div>
</div>
<div class="flex gap-4  items-center">
    <div class="auth-input-div w-full ">
        <p class="text-(--gray)">Prix</p>
        {{ form_widget(form.price , {
        'attr' : { 'class' : "auth-input" }
        }) }}
        <div class="alert">
            {{ form_errors(form.price) }}
        </div>
    </div>
    <div class="auth-input-div ">
        <p class="text-(--gray)">Unité</p>
        {{ form_widget(form.unit , {
        'attr' : { 'class' : "auth-input" }
        }) }}
        <div class="alert">
            {{ form_errors(form.unit) }}
        </div>
    </div>
</div>

<div class="flex items-center gap-4 justify-end">
    <a href="{{ path('app_product_index')}}">Annuler</a>
    <button class="btn blue-btn">Enregistrer</button>
</div>
{{ form_end(form) }}