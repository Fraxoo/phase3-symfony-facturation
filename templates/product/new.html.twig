{% extends 'base.html.twig' %}

{% block title %}New Product{% endblock %}

{% block body %}
<div class="flex flex-col h-screen justify-between p-8">
    <div class="flex flex-col gap-4 items-center">
        <h1 class="uppercase text-[24px] text-(--title-color) font-bold">Ajouter un nouveau produit</h1>
    
        {{ include('product/_form.html.twig') }}
    </div>
    <div class="flex flex-col gap-4 ">
        <h3 class="text-center text-[24px] text-(--title-color) font-bold">Produits & Services existant</h3>
        <twig:ProductList products="{{ products }}" />
    </div>

</div>
{% endblock %}
