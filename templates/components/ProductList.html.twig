<table class="table product-list rounded-2xl p-2" {{attributes}}>
	<thead class=" border-b border-black">
		<tr>
			<th class="text-start py-4 px-6">Nom</th>
			<th class="text-start py-4 px-6">Description</th>
			<th class="text-center py-4 px-6">Prix unitaire</th>
			<th class="text-end py-4 px-6">Actions</th>
		</tr>
	</thead>
	<tbody>
		{% for product in products %}
		<tr class="bg-white border-t border-(--gray-border) hover:bg-(--primary-bg-color) transition-colors ">
			<td class="py-4 px-6">{{ product.name }}</td>
			<td class="py-4 px-6">{{ product.description }}</td>
			<td class="text-center py-4 px-6">{{ product.price }} / {{ product.unit.value }}</td>
			<td class="flex gap-4 justify-end py-4 px-6">
				<a class="text-(--primary-color)" href="{{ path('app_product_edit', {'id': product.id}) }}">
					<i class="fa-solid fa-pencil"></i>
				</a>
				<form action="{{path('app_product_delete' , {'id': product.id})}}" method="post"
					onsubmit="return confirm('Are you sure you want to delete this product?');">
					<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
					<button type="submit" class="text-red-500">
						<i class="fa-regular fa-trash-can"></i>
					</button>
				</form>
			</td>
		</tr>
		{% else %}
		<tr>
			<td class="text-center" colspan="7">Aucun produit pour le moment</td>
		</tr>
		{% endfor %}
	</tbody>
</table>