
	<table class="table" {{attributes}}>
		<thead>
			<tr>
				<th>Name</th>
				<th>Description</th>
				<th>Price</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for product in products %}
				<tr>
					<td>{{ product.name }}</td>
					<td>{{ product.description }}</td>
					<td>{{ product.price }}</td>
					<td class="flex gap-4 items-center">
						<a class="text-(--primary-color)" href="{{ path('app_product_edit', {'id': product.id}) }}">
							<i class="fa-solid fa-pencil"></i>
						</a>
						<a class="text-red-500" href="{{ path('app_product_delete', {'id': product.id}) }}">
							<i class="fa-regular fa-trash-can"></i>
						</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="7">Aucun produit pour le moment</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
