{% extends 'base.html.twig' %}

{% block title %}Edit Client{% endblock %}

{% block body %}
<div class="flex justify-center items-center h-screen">
    <div class="auth-form w-1/3">
        <div class="flex justify-between">
            <div class="flex flex-col">
                <h3 class="font-bold text-[20px]">Client - {{ client.name }}</h3>
                <p class="font-bold text-(--gray)">Modifier un client</p>
            </div>
            <a href="{{ path('app_client_index')}}"><i class="fa-solid fa-xmark"></i></a>
        </div>
        {{ include('client/_form.html.twig', {'button_label': 'Update'}) }}
    </div>

</div>
{% endblock %}
